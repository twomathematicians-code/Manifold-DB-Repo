# =============================================================================
# Manifold DB — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python bytecode & compiled extensions
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---------------------------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------------------------
*.egg-info/
*.egg
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.whl

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.benchmark/
benchmark_results.json
test-results/

# ---------------------------------------------------------------------------
# Type checking & linting caches
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.dmypy.json

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ---------------------------------------------------------------------------
# IDE & editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ---------------------------------------------------------------------------
# Data files (numpy arrays, large datasets)
# ---------------------------------------------------------------------------
*.npy
*.npz
*.nii
*.nii.gz
*.h5
*.hdf5
*.h5py
*.pkl
*.pickle
*.parquet
*.feather
*.arrow
*.csv.gz
data/raw/
data/processed/

# ---------------------------------------------------------------------------
# Model files
# ---------------------------------------------------------------------------
*.pt
*.pth
*.onnx
*.safetensors
checkpoints/
saved_models/

# ---------------------------------------------------------------------------
# Secrets & local configuration
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
config.local.yaml
config.local.yml
config.local.json
secrets/
*.key
*.pem

# ---------------------------------------------------------------------------
# Docker volumes & local data
# ---------------------------------------------------------------------------
docker-data/
postgres-data/
redis-data/
*.db
*.sqlite
*.sqlite3

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Documentation build
# ---------------------------------------------------------------------------
site/
docs/_build/

# ---------------------------------------------------------------------------
# Profiling
#-----------
*.prof
*.lprof
*.memory_prof

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
